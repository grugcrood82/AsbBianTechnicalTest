{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      },
      "enableLiveMetricsFilters": true
    }
  },
  "extensions": {
    "OpenApi": {
      "enabled": true,
      "forceHttps": false,
      "swagger": {
        "ui": {
          "path": "swagger/ui"
        },
        "json": {
          "path": "swagger/v1/swagger.json"
        }
      },
      "info": {
        "title": "Assemble Events API",
        "version": "1.0.0"
      }
    }
  },
  "functionTimeout": "00:05:00"
}